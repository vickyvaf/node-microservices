{
  "name": "node-microservices",
  "version": "1.0.0",
  "description": "Bun + Express Microservices implementation",
  "main": "index.js",
  "scripts": {
    "start:user": "bun user-service/app.js",
    "start:product": "bun product-service/app.js",
    "start:order": "bun order-service/app.js",
    "start:all": "concurrently \"bun run start:user\" \"bun run start:product\" \"bun run start:order\"",
    "docker:user": "docker compose -f user-service/docker-compose.yml up --build -d",
    "docker:product": "docker compose -f product-service/docker-compose.yml up --build -d",
    "docker:order": "docker compose -f order-service/docker-compose.yml up --build -d",
    "docker:monitoring": "docker compose -f monitoring/docker-compose.yml up --build -d",
    "docker:all": "bun run docker:user && bun run docker:product && bun run docker:order && bun run docker:monitoring",
    "docker:down:user": "docker compose -f user-service/docker-compose.yml down",
    "docker:down:product": "docker compose -f product-service/docker-compose.yml down",
    "docker:down:order": "docker compose -f order-service/docker-compose.yml down",
    "docker:down:monitoring": "docker compose -f monitoring/docker-compose.yml down",
    "docker:down:all": "bun run docker:down:user && bun run docker:down:product && bun run docker:down:order && bun run docker:down:monitoring"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "express": "^4.18.2",
    "express-prom-bundle": "^8.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
