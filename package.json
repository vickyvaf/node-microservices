{
  "name": "node-microservices",
  "version": "1.0.0",
  "description": "Bun + Express Microservices implementation",
  "main": "index.ts",
  "scripts": {
    "start:user": "bun user-service/app.ts",
    "start:product": "bun product-service/app.ts",
    "start:order": "bun order-service/app.ts",
    "start:all": "concurrently \"bun run start:user\" \"bun run start:product\" \"bun run start:order\"",
    "docker:user": "docker compose up user-service --build -d",
    "docker:product": "docker compose up product-service --build -d",
    "docker:order": "docker compose up order-service --build -d",
    "docker:monitoring": "docker compose up prometheus loki promtail grafana portainer --build -d",
    "docker:all": "docker compose up --build -d",
    "docker:down:user": "docker compose stop user-service",
    "docker:down:product": "docker compose stop product-service",
    "docker:down:order": "docker compose stop order-service",
    "docker:down:monitoring": "docker compose stop prometheus loki promtail grafana portainer",
    "docker:down:all": "docker compose down"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "express": "^4.18.2",
    "express-prom-bundle": "^8.0.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "bun-types": "^1.3.10",
    "concurrently": "^8.2.2",
    "typescript": "^5.9.3"
  }
}
