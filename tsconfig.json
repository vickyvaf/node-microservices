{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": ".",
        "types": [
            "bun-types"
        ]
    },
    "include": [
        "user-service/**/*.ts",
        "product-service/**/*.ts",
        "order-service/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}